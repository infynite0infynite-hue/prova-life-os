{
  "expo": {
    "name": "ProvaLife OS",
    "slug": "prova-life-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prova-life-os",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08000F"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.provasixsorganization.provalifeos"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "513ccb22-cfa3-4976-8e19-bd3288380381"
      }
    },
    "owner": "provasixs-organization"
  }
}
